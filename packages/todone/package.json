{
  "name": "todone",
  "version": "1.0.1",
  "type": "module",
  "description": "Never forget to follow up on your code's TODOs, maintain code quality, and pay back your technical debt.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cprecioso/todone.git"
  },
  "homepage": "https://github.com/cprecioso/todone/tree/main/packages/todone#readme",
  "bugs": {
    "url": "https://github.com/cprecioso/todone/issues"
  },
  "author": "Carlos Precioso <npm@precioso.design>",
  "license": "ISC",
  "packageManager": "yarn@4.17.1",
  "engines": {
    "node": ">=24"
  },
  "bin": "dist/bin.js",
  "imports": {
    "#/package.json": "./package.json",
    "#/index": "./src/index.ts",
    "#/plugin": "./src/plugin.ts",
    "#/types": "./src/types.ts",
    "#/lib/*": "./src/lib/*.ts"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./reporters": {
      "types": "./dist/reporters.d.ts",
      "default": "./dist/reporters.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit -p .",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@cprecioso/async-iterable-helpers": "^0.3.0",
    "@std/streams": "jsr:^1.1.1",
    "c12": "^4.0.0-beta.5",
    "chalk": "^5.6.2",
    "clipanion": "^4.0.0-rc.4",
    "dedent": "^1.7.2",
    "globby": "^16.2.0",
    "jiti": "^2.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@todone/internal-build": "workspace:^",
    "@types/node": "^24.13.2",
    "tsdown": "^0.22.3",
    "type-fest": "^5.8.0",
    "typescript": "~6.0.3"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "sideEffects": false
}
