{
  "compilerOptions": {
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2025",
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "types": ["node"]
  }
}
