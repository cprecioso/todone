{
  "name": "@todone/plugin-caniuse",
  "version": "1.0.1",
  "type": "module",
  "description": "A todone plugin that will alert you when a feature is supported by your target browsers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/todone-run/todone.git",
    "directory": "packages/plugin-caniuse"
  },
  "bugs": {
    "url": "https://github.com/todone-run/todone/issues"
  },
  "author": "Carlos Precioso <npm@precioso.design>",
  "license": "ISC",
  "packageManager": "yarn@4.17.1",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit -p .",
    "dev": "tsdown --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "todone": "workspace:^"
  },
  "dependencies": {
    "browserslist": "^4.28.5",
    "caniuse-lite": "^1.0.30001803",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@todone/internal-build": "workspace:^",
    "@types/caniuse-lite": "^1.0.5",
    "@types/node": "^24.13.3",
    "todone": "workspace:^",
    "tsdown": "^0.22.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "sideEffects": false
}
