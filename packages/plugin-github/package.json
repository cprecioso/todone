{
  "name": "@todone/plugin-github",
  "version": "0.7.2",
  "type": "module",
  "description": "A todone plugin that will alert you when an GitHub issue or pull request has been resolved",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/todone-run/todone.git",
    "directory": "packages/plugin-github"
  },
  "bugs": {
    "url": "https://github.com/todone-run/todone/issues"
  },
  "author": "Carlos Precioso <npm@precioso.design>",
  "license": "ISC",
  "packageManager": "yarn@4.17.1",
  "imports": {
    "#/package.json": "./package.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit -p .",
    "dev": "tsdown --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "todone": "workspace:^"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@cprecioso/async-iterable-helpers": "^0.4.0",
    "hast-util-from-html": "^2.0.3",
    "hast-util-to-html": "^9.0.5",
    "hastscript": "^9.0.1",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "mdast-zone": "^6.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "octokit": "^5.0.5",
    "unist-builder": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@todone/internal-build": "workspace:^",
    "@types/mdast": "^4.0.4",
    "msw": "^2.15.0",
    "todone": "workspace:^",
    "tsdown": "^0.22.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "sideEffects": false
}
